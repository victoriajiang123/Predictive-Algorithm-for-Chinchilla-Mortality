{
  "manifest_version": 3,
  "name": "Click & Save",
  "version": "1.0",
  "description": "Clicks a button on a page, scrapes the resulting data, and saves it via the native Save As dialog.",
  "permissions": ["downloads", "activeTab", "scripting", "nativeMessaging", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["page_hook.js"],
      "all_frames": true,
      "world": "MAIN",
      "run_at": "document_start",
      "match_origin_as_fallback": true
    }
  ]
}
