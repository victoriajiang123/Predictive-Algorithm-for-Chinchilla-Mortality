{
  "manifest_version": 3,
  "name": "Click & Save",
  "version": "1.0",
  "description": "Clicks a button on a page, scrapes the resulting data, and saves it via the native Save As dialog.",
  "permissions": ["downloads", "activeTab", "scripting", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
